#!/bin/bash
set -euo pipefail

# Determine our location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ENV_FILE="${SCRIPT_DIR}/sheath-env.sh"

export SHELL="$SCRIPT_DIR/cs"
export BASH_ENV="$ENV_FILE"

# If invoked as a shell (either 0 args for interactive, or -c/-i/-l flags)
if [[ $# -eq 0 ]] || [[ "$1" == -* ]]; then
    if [[ -f "$ENV_FILE" ]]; then
        source "$ENV_FILE"
    elif [[ "$1" == -* ]]; then
        echo -e "\x1b[31mclaw-sheath error:\x1b[0m Environment file not found at $ENV_FILE" >&2
        exit 1
    fi
    exec bash "$@"
else
    # Claude-specific overrides to force Claude to use our proxy for tool-based commands
    export CLAUDE_CODE_SHELL="$SCRIPT_DIR/cs"
    export CLAUDE_CODE_SHELL_PREFIX="$SCRIPT_DIR/cs -c"

    # Invoked as a launcher wrapper (e.g. `cs openclaw` or `cs open -a Antigravity`). 
    # BASH_ENV handles the environment injection for subshells spawned by the process.
    if [[ "$1" == "open" ]]; then
        exec "$1" --env SHELL="$SCRIPT_DIR/cs" --env BASH_ENV="$ENV_FILE" "${@:2}"
    else
        exec "$@"
    fi
fi
